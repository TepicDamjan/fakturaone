# =============================================================================
# Lokalni razvoj — kopiraj u .env.local
# =============================================================================

NEXT_PUBLIC_SUPABASE_URL=https://TVOJ-PROJEKAT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role — SAMO na serveru (webhook, sync pretplate). Nikad u klijentu!
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Admin panel — zarezom odvojena lista emailova koji imaju pristup /admin
ADMIN_EMAILS=admin@example.com

# Resend — slanje faktura emailom (https://resend.com)
RESEND_API_KEY=re_xxxxxxxx
EMAIL_FROM=FakturaOne <noreply@fakturaone.app>

# Freemius — pretplate (https://freemius.com)
FREEMIUS_PRODUCT_ID=
FREEMIUS_SECRET_KEY=
FREEMIUS_API_BEARER_TOKEN=
FREEMIUS_PLAN_PROFESSIONAL=
FREEMIUS_PLAN_BUSINESS=
FREEMIUS_CHECKOUT_REDIRECT_URL=http://localhost:3000/api/freemius/checkout

# =============================================================================
# Vercel produkcija — postavi u Project → Settings → Environment Variables
# =============================================================================
#
# NEXT_PUBLIC_SITE_URL=https://fakturaone.app
# FREEMIUS_CHECKOUT_REDIRECT_URL=https://fakturaone.app/api/freemius/checkout
#
# Supabase → Authentication → URL Configuration:
#   Site URL: https://fakturaone.app
#   Redirect URLs: https://fakturaone.app/auth/callback
#
# Freemius Dashboard:
#   Redirect URL: https://fakturaone.app/api/freemius/checkout
#   Webhook URL:  https://fakturaone.app/api/webhooks/freemius
#
# Resend: verifikuj domen fakturaone.app za EMAIL_FROM
