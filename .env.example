# Kopiraj u .env.local i popuni vrednosti iz Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://TVOJ-PROJEKAT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Bazni URL (lokalno / produkcija)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Produkcija: https://fakturaone.app ili https://app.fakturaone.app

# Resend — slanje faktura emailom (https://resend.com)
RESEND_API_KEY=re_xxxxxxxx
# Domen fakturaone.app mora biti verifikovan u Resend-u
EMAIL_FROM=FakturaOne <noreply@fakturaone.app>
